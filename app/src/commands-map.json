[
    {
        "name": "Graphics",
        "description": "Set up the display. depth = bitplanes (1–5), giving 2^depth colours. Must be called before any drawing.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "width",
                "type": "integer"
            },
            {
                "name": "height",
                "type": "integer"
            },
            {
                "name": "depth",
                "type": "integer"
            }
        ],
        "zone": "setup"
    },
    {
        "name": "Cls",
        "description": "Clear the back buffer using the blitter. Fill colour is set by ClsColor.",
        "type": "global",
        "return": "void",
        "args": [],
        "zone": "any"
    },
    {
        "name": "ClsColor",
        "description": "Set the palette index used by Cls to fill the background. Default is 0 (black).",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "color",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "Color",
        "description": "Set the current drawing colour to a palette index (0–31). Used by Plot, Line, Rect, Box, and Text.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "PaletteColor",
        "description": "Set palette entry n. r, g, b are OCS 4-bit values (0–15). Takes effect at the next ScreenFlip.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "n",
                "type": "integer"
            },
            {
                "name": "r",
                "type": "integer"
            },
            {
                "name": "g",
                "type": "integer"
            },
            {
                "name": "b",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "WaitVbl",
        "description": "Wait for the next vertical blank without flipping buffers. Useful for timing-only synchronisation.",
        "type": "global",
        "return": "void",
        "args": [],
        "zone": "any"
    },
    {
        "name": "Text",
        "description": "Draw a string at (x, y) using the current font and colour. Supports newlines.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "x",
                "type": "integer"
            },
            {
                "name": "y",
                "type": "integer"
            },
            {
                "name": "string",
                "type": "string"
            }
        ],
        "zone": "any"
    },
    {
        "name": "End",
        "description": "Exit the program immediately and restore the OS.",
        "type": "global",
        "return": "void",
        "args": [],
        "zone": "any"
    },
    {
        "name": "Delay",
        "description": "Pause for the given number of frames (1 frame ≈ 20 ms PAL / 17 ms NTSC).",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "frames",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "Plot",
        "description": "Draw a single pixel at (x, y) in the current colour.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "x",
                "type": "integer"
            },
            {
                "name": "y",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "Line",
        "description": "Draw a line from (x1, y1) to (x2, y2) in the current colour.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "x1",
                "type": "integer"
            },
            {
                "name": "y1",
                "type": "integer"
            },
            {
                "name": "x2",
                "type": "integer"
            },
            {
                "name": "y2",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "Rect",
        "description": "Draw a hollow rectangle outline at (x, y) with the given width and height.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "x",
                "type": "integer"
            },
            {
                "name": "y",
                "type": "integer"
            },
            {
                "name": "w",
                "type": "integer"
            },
            {
                "name": "h",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "Box",
        "description": "Draw a filled rectangle at (x, y) with the given width and height using the blitter.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "x",
                "type": "integer"
            },
            {
                "name": "y",
                "type": "integer"
            },
            {
                "name": "w",
                "type": "integer"
            },
            {
                "name": "h",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "WaitKey",
        "description": "Halt execution until a key is pressed. Uses interrupt-driven CIA-A keyboard input.",
        "type": "global",
        "return": "void",
        "args": [],
        "zone": "any"
    },
    {
        "name": "ScreenFlip",
        "description": "Swap front and back buffers. Call once per frame after all drawing is done. Also triggers the copper-list swap.",
        "type": "global",
        "return": "void",
        "args": [],
        "zone": "frame"
    },
    {
        "name": "CopperColor",
        "description": "Change the background colour (COLOR00) at scanline y via the copper. r, g, b are 0–15. Enables raster bars.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "y",
                "type": "integer"
            },
            {
                "name": "r",
                "type": "integer"
            },
            {
                "name": "g",
                "type": "integer"
            },
            {
                "name": "b",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "LoadSample",
        "description": "Register a raw PCM audio sample. File must be 8-bit unsigned, mono. Only declares the asset — no chip RAM is used until PlaySample.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            },
            {
                "name": "file",
                "type": "string"
            }
        ],
        "zone": "setup"
    },
    {
        "name": "PlaySample",
        "description": "Play a sample on Paula channel 0–3, looping continuously. period controls pitch (lower = higher pitch; 428 ≈ middle C). volume is 0–64.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            },
            {
                "name": "channel",
                "type": "integer"
            },
            {
                "name": "period",
                "type": "integer"
            },
            {
                "name": "volume",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "PlaySampleOnce",
        "description": "Play a sample once on Paula channel 0–3, then go silent. Uses the same period/volume convention as PlaySample.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            },
            {
                "name": "channel",
                "type": "integer"
            },
            {
                "name": "period",
                "type": "integer"
            },
            {
                "name": "volume",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "StopSample",
        "description": "Stop DMA playback on Paula channel 0–3 immediately.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "channel",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "LoadImage",
        "description": "Load a raw planar image from disk into chip RAM. width/height are parsed automatically.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            },
            {
                "name": "file",
                "type": "string"
            }
        ],
        "zone": "setup",
        "outputs": [
            {
                "name": "index",
                "type": "integer"
            }
        ]
    },
    {
        "name": "DrawImage",
        "description": "Draw a loaded image at (x, y). Optional frame selects a frame from an animation strip (0-based).",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            },
            {
                "name": "x",
                "type": "integer"
            },
            {
                "name": "y",
                "type": "integer"
            },
            {
                "name": "frame",
                "type": "integer",
                "optional": true
            }
        ],
        "zone": "any"
    },
    {
        "name": "PokeB",
        "description": "Write an 8-bit value to an absolute hardware address. No bounds checking — direct chip register access.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "addr",
                "type": "integer"
            },
            {
                "name": "val",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "PokeW",
        "description": "Write a 16-bit value to an absolute hardware address. Address should be word-aligned.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "addr",
                "type": "integer"
            },
            {
                "name": "val",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "PokeL",
        "description": "Write a 32-bit value to an absolute hardware address. Address should be longword-aligned.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "addr",
                "type": "integer"
            },
            {
                "name": "val",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "Poke",
        "description": "Alias for PokeL. Write a 32-bit value to an absolute hardware address.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "addr",
                "type": "integer"
            },
            {
                "name": "val",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "SetBackground",
        "description": "Set the image used as the static background for Bob restore. Must be called before any DrawBob.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            }
        ],
        "zone": "setup"
    },
    {
        "name": "LoadMask",
        "description": "Load a 1-bpp mask file for a Bob image. The mask determines which pixels are transparent during DrawBob.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            },
            {
                "name": "file",
                "type": "string"
            }
        ],
        "zone": "setup"
    },
    {
        "name": "DrawBob",
        "description": "Queue a Bob (blitter object) to be drawn at (x, y). Optional frame for animated bobs. Bobs are flushed automatically before ScreenFlip.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            },
            {
                "name": "x",
                "type": "integer"
            },
            {
                "name": "y",
                "type": "integer"
            },
            {
                "name": "frame",
                "type": "integer",
                "optional": true
            }
        ],
        "zone": "any"
    },
    {
        "name": "LoadAnimImage",
        "description": "Load an animation strip. frameCount sets how many frames are in the strip; each frame is width×height pixels.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            },
            {
                "name": "file",
                "type": "string"
            },
            {
                "name": "width",
                "type": "integer"
            },
            {
                "name": "height",
                "type": "integer"
            },
            {
                "name": "count",
                "type": "integer"
            }
        ],
        "zone": "setup"
    },
    {
        "name": "LoadTileset",
        "description": "Load a tileset from a .tset file. The file header contains tile size, tile count, depth and palette. Slot 0 sets the display palette.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "slot",
                "type": "integer"
            },
            {
                "name": "file",
                "type": "string"
            }
        ],
        "zone": "setup"
    },
    {
        "name": "LoadTilemap",
        "description": "Load a binary tilemap file (.bmap). Format: 8-byte header (map_width, map_height, tile_w, tile_h as words) followed by map_width*map_height tile-index words (0-based, row-major).",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "slot",
                "type": "integer"
            },
            {
                "name": "file",
                "type": "string"
            }
        ],
        "zone": "setup"
    },
    {
        "name": "DrawTilemap",
        "description": "Render the visible portion of a tilemap into the back buffer. With scrollX/scrollY: explicit camera position in pixels. Without: uses the active viewport camera (SetCamera). Tile dimensions and map size are read from the tilemap header at runtime.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "tmSlot",
                "type": "integer"
            },
            {
                "name": "tsSlot",
                "type": "integer"
            },
            {
                "name": "scrollX",
                "type": "integer",
                "optional": true
            },
            {
                "name": "scrollY",
                "type": "integer",
                "optional": true
            }
        ],
        "zone": "any"
    },
    {
        "name": "SetViewport",
        "description": "Define viewport index covering screen lines y1..y2 (inclusive). Viewports must cover the full screen without gaps or overlaps. y1/y2 must be integer literals.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            },
            {
                "name": "y1",
                "type": "integer"
            },
            {
                "name": "y2",
                "type": "integer"
            }
        ],
        "zone": "setup"
    },
    {
        "name": "Viewport",
        "description": "Switch the drawing context to viewport index. All subsequent drawing commands target this viewport. index must be an integer literal.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "SetCamera",
        "description": "Set the 2D camera position of the active viewport. DrawBob translates world-space positions by (x, y). DrawTilemap without explicit scroll args uses this position.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "x",
                "type": "integer"
            },
            {
                "name": "y",
                "type": "integer"
            }
        ],
        "zone": "any"
    },
    {
        "name": "SetTilemap",
        "description": "Register a tilemap+tileset pair as the active scrolling background for Bob restore. Replaces SetBackground. Must be called before DrawBob when using a tilemap background.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "tmSlot",
                "type": "integer"
            },
            {
                "name": "tsSlot",
                "type": "integer"
            }
        ],
        "zone": "setup"
    },
    {
        "name": "LoadFont",
        "description": "Load a raw font image. chars defines the character set order in the image; charW/charH define glyph size in pixels.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer"
            },
            {
                "name": "chars",
                "type": "string"
            },
            {
                "name": "file",
                "type": "string"
            },
            {
                "name": "charW",
                "type": "integer"
            },
            {
                "name": "charH",
                "type": "integer"
            }
        ],
        "zone": "setup"
    },
    {
        "name": "UseFont",
        "description": "Switch to a previously loaded font. Omit index to revert to the built-in 8×8 font.",
        "type": "global",
        "return": "void",
        "args": [
            {
                "name": "index",
                "type": "integer",
                "optional": true
            }
        ],
        "zone": "any"
    }
]